{
  "multipart": [
    {
      "apply": {
        "model": "psithurism:block/horizontal_paper_wall_post"
      }
    },
    {
      "apply": {
        "model": "psithurism:block/horizontal_paper_wall_side"
      },
      "when": {
        "north": "true"
      }
    },
    {
      "apply": {
        "model": "psithurism:block/horizontal_paper_wall_side",
        "y": 90
      },
      "when": {
        "east": "true"
      }
    },
    {
      "apply": {
        "model": "psithurism:block/horizontal_paper_wall_side_alt"
      },
      "when": {
        "south": "true"
      }
    },
    {
      "apply": {
        "model": "psithurism:block/horizontal_paper_wall_side_alt",
        "y": 90
      },
      "when": {
        "west": "true"
      }
    },
    {
      "apply": {
        "model": "psithurism:block/horizontal_paper_wall_noside"
      },
      "when": {
        "north": "false"
      }
    },
    {
      "apply": {
        "model": "psithurism:block/horizontal_paper_wall_noside_alt"
      },
      "when": {
        "east": "false"
      }
    },
    {
      "apply": {
        "model": "psithurism:block/horizontal_paper_wall_noside_alt",
        "y": 90
      },
      "when": {
        "south": "false"
      }
    },
    {
      "apply": {
        "model": "psithurism:block/horizontal_paper_wall_noside",
        "y": 270
      },
      "when": {
        "west": "false"
      }
    }
  ]
}